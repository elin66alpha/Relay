# HTTP backend listened by the Flutter app.
PORT=8787
# Tailscale mode (recommended): bind 0.0.0.0 so the tailnet interface is
# reachable. Direct mode (VPS/public host) also uses 0.0.0.0. Tailscale's
# WireGuard transport keeps traffic private and encrypted; the backend is not
# exposed to the public internet.
HOST=0.0.0.0

# Auth tokens live in server/tokens.json (one per device, revocable), created by
# `npm run credential`. The Flutter app sends one as: Authorization: Bearer <token>.

# Filled by npm run credential.
MACHINE_ID=
MACHINE_NAME=
# The address the app uses to reach this backend. In Tailscale mode this is the
# stable MagicDNS URL (http://<machine>.<tailnet>.ts.net:8787), auto-detected by
# `npm run credential`. In direct mode it is your public IP/domain URL.
PUBLIC_BASE_URL=

# Default work directory a brand-new device starts from (each device then holds
# its own current path locally). Leave empty to use ~/agent_deck.
AGENTDECK_DEFAULT_DIR=

# Max runtime for one CLI agent turn. Default: 3600000 (60 minutes).
AGENT_TIMEOUT_MS=3600000

# Quota reset events are delivered to connected app clients over /api/events.
ENABLE_QUOTA_WATCH=true
QUOTA_POLL_MS=300000
