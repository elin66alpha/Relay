# HTTP backend listened by the Flutter app.
PORT=8787
# Cloudflare Tunnel and Quick Tunnel modes reach the backend over localhost.
# Direct mode for a VPS/public host should set this to 0.0.0.0.
HOST=127.0.0.1

# Auth tokens live in server/tokens.json (one per device, revocable), created by
# `npm run credential`. The Flutter app sends one as: Authorization: Bearer <token>.

# Filled by npm run credential.
MACHINE_ID=
MACHINE_NAME=
# The address the app uses to reach this backend. Named Cloudflare Tunnel and
# direct mode use a stable URL. Quick Tunnel uses the latest trycloudflare URL.
PUBLIC_BASE_URL=

# Optional PM2 cloudflared command arguments. setup.sh fills this when you pick
# a named Cloudflare Tunnel or Quick Tunnel.
AGENTDECK_TUNNEL_MODE=
CLOUDFLARED_BIN=
CLOUDFLARED_ARGS=

# Default work directory a brand-new device starts from (each device then holds
# its own current path locally). Leave empty to use ~/agent_deck.
AGENTDECK_DEFAULT_DIR=

# Max runtime for one CLI agent turn. Default: 3600000 (60 minutes).
AGENT_TIMEOUT_MS=3600000

# Optional Windows override for directory zip downloads. Defaults to powershell.exe.
POWERSHELL_BIN=

# Quota reset events are delivered to connected app clients over /api/events.
ENABLE_QUOTA_WATCH=true
QUOTA_POLL_MS=300000
